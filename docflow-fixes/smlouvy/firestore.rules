rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- USERS tree: contracts, family members, settings, etc. ---
    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // --- FAMILY INVITES ---
    // Doc id = invited email with . and @ replaced by _
    // Only the inviter (authenticated) can create/delete their own invites.
    // Invitee can read an invite (to check if they were invited) when signed in.
    match /family_invites/{inviteId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.inviterUid == request.auth.uid
                    && request.resource.data.keys().hasOnly(
                         ['invitedEmail','inviterUid','inviterName','invitedAt']
                       );

      allow update, delete: if isSignedIn()
                            && resource.data.inviterUid == request.auth.uid;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
